#!/usr/bin/env node

const { execSync } = require('child_process');
const path = require('path');
const os = require('os');
const fs = require('fs');

// Get the first argument (should be 'artisan' or the script)
const args = process.argv.slice(2);

// Detect PHP binary
let phpBinary = process.env.PHP_BIN || 'php';

// On Windows with Laragon, use the full path
if (os.platform() === 'win32' && !process.env.PHP_BIN) {
    const laragonPhpPath = 'C:\\laragon\\bin\\php\\php-8.3.30-Win32-vs16-x64\\php.exe';
    if (fs.existsSync(laragonPhpPath)) {
        phpBinary = laragonPhpPath;
    }
}

// Build and execute the command
try {
    const projectRoot = path.dirname(path.dirname(__filename));
    const command = `"${phpBinary}" "${path.join(projectRoot, args[0])}" ${args.slice(1).join(' ')}`;
    
    execSync(command, {
        stdio: 'inherit',
        cwd: projectRoot,
        shell: true,
    });
} catch (error) {
    process.exit(error.status || 1);
}
